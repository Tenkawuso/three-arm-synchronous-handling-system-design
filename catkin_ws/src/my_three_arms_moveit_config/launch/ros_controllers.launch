<?xml version="1.0"?>
<launch>

  <!-- Load joint controller configurations from YAML file to parameter server -->
  <rosparam file="$(find my_three_arms_moveit_config)/config/ros_controllers.yaml" command="load"/>

  <!-- Load the controllers -->
  <node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false"
    output="screen" args="arm1_group_controller arm2_group_controller arm3_group_controller arm1_gripper_controller arm2_gripper_controller arm3_gripper_controller"/>

</launch>
